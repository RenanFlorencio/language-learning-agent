        <mxCell id="LPWrPx7DY98C0RRhd-94-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;div&gt;&lt;b&gt;🧠 Orchestrator Agent&lt;/b&gt;&lt;br&gt;(LangGraph StateGraph)&lt;br&gt;&lt;br&gt;• Parses user intent&lt;br&gt;• Plans sub-agent tasks&lt;br&gt;• Manages state &amp;amp; flow&lt;br&gt;• Routes to correct agents&lt;/div&gt;" vertex="1">
